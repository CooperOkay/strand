{
  "name": "strandjs",
  "version": "0.1.0",
  "description": "Reactive proxies for JS — wrap any target, auto-track dependencies, react to changes. Only possible in JS.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./sqlite": {
      "import": "./dist/sqlite.js",
      "require": "./dist/sqlite.cjs",
      "types": "./dist/sqlite.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/sqlite.ts --format esm,cjs --dts --clean",
    "test": "tsx test/smoke.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "reactive",
    "proxy",
    "signal",
    "state",
    "sqlite",
    "tracking"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
